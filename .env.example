# ============================================
# isin_nest 環境變數範例（專案根目錄 .env）
# ============================================
# 使用方式：複製為 .env 並依實際環境修改
#   cp .env.example .env
# ============================================

# --------------------------------------------
# Production 必填（部署後端至少需設定）
# --------------------------------------------
# NODE_ENV=production
# PORT=3000
# DB_HOST=
# DB_PORT=5432
# DB_USER=
# DB_PASS=
# DB_NAME=
# STAFF_PAGE_LOCK_PASSWORD=
# CNC_PATH=
# DWG_PATH=
# NESTING_PATH=
# LIBREOFFICE_PATH=/usr/bin/soffice

# --------------------------------------------
# 後端 / PostgreSQL（主資料庫）
# --------------------------------------------
# DB_HOST：僅在本機直接跑後端（npm/nest，非 Docker）連 Postgres 時使用，例如 localhost。
# docker compose 內的後端服務會固定連到資料庫容器主機名 db，不需也不應在此改為 db。
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password
DB_NAME=isin

# 備用變數名（部分腳本會使用）
# DB_USERNAME=postgres
# DB_PASSWORD=your_password
# DB_DATABASE=isin

# 選填：啟動時自動執行 migration、schema 同步（建議開發以外關閉）
# DB_MIGRATIONS_RUN=false
# DB_SYNC：開發（含 docker compose）可 true；正式環境請 false 並改用 migration
DB_SYNC=true

# --------------------------------------------
# Docker Compose（與根目錄 docker-compose.yml 對齊）
# --------------------------------------------
# 主機對外埠（未設定時 compose 預設：5432 / 3000 / 3001）
# HOST_DB_PORT=5432
# HOST_BACKEND_PORT=3000
# HOST_FRONTEND_PORT=3001
#
# Postgres 容器：compose 會將上方的 DB_USER / DB_PASS / DB_NAME 對應為 POSTGRES_*，
# 後端容器亦使用同一組 DB_*（連線主機 db 已在 compose 內設定），請勿混用不同帳密。
#
# JWT（compose 與本機後端共用；正式環境請改成強隨機字串）
JWT_SECRET=your-secret-key

# --------------------------------------------
# 後端執行環境
# --------------------------------------------
NODE_ENV=development
PORT=3000

# --------------------------------------------
# 來源資料庫（遷移腳本用，如 copy-staff.ts）
# 舊 MySQL 等來源連線，若未設則部分腳本會 fallback 到 DB_*
# --------------------------------------------
# SOURCE_DB_HOST=localhost
# SOURCE_DB_PORT=3306
# SOURCE_DB_USER=root
# SOURCE_DB_PASS=
# SOURCE_DB_NAME=isin2
# SOURCE_DB_USERNAME=root
# SOURCE_DB_PASSWORD=
# SOURCE_DB_DATABASE=isin2

# --------------------------------------------
# Access 相關（遷移腳本：migrate-quote、migrate-customer、analyze-access）
# --------------------------------------------
# ACCESS_DB_PASSWORD=
# ACCESS_FILE_PATH=legacy/quote.mdb

# --------------------------------------------
# 路徑（後端 CRM / Nesting、LibreOffice）
# --------------------------------------------
# LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
# NESTING_PATH=path/nesting
# CNC_PATH=path/cnc
# DWG_PATH=path/dwg

# --------------------------------------------
# 腳本用（可選）
# --------------------------------------------
# create-admin.ts
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# FORCE_UPDATE=false

# migrate-quote-from-access.ts
# SKIP_COUNT=0
# ONLY_MODE=quote|quote-item

# analyze-access.ts
# MYSQL_TABLE_NAME=

# staff.controller.ts
# STAFF_PAGE_LOCK_PASSWORD=

# 測試 / CI
# CI=false

# --------------------------------------------
# 前端（Vite 建置時會讀取；docker compose build frontend 時亦傳入）
# --------------------------------------------
VITE_API_BASE_URL=/api
